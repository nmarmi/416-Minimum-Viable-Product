# For same-domain Vercel proxy deployment, you usually do not need any REACT_APP API vars.
# Keep this empty unless you want the frontend to call backend directly (cross-origin).

# Optional direct-backend mode:
# REACT_APP_API_BASE_URL=https://<your-draftiq-backend-domain>
# REACT_APP_API_URL=https://<your-draftiq-backend-domain>/auth
# REACT_APP_LEAGUES_API_URL=https://<your-draftiq-backend-domain>/leagues
# REACT_APP_PLAYERS_API_URL=https://<your-draftiq-backend-domain>
